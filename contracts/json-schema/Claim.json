{
  "$defs": {
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "A pointer to a piece of evidence backing a claim.",
      "properties": {
        "kind": {
          "enum": [
            "measurement",
            "finding",
            "observation",
            "external"
          ],
          "title": "Kind",
          "type": "string"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "Uncertainty": {
      "additionalProperties": false,
      "description": "How sure the narrator is about a claim.",
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        }
      },
      "required": [
        "confidence"
      ],
      "title": "Uncertainty",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "One assertion inside a narrative, with optional evidence + uncertainty.",
  "properties": {
    "evidence": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Evidence",
      "type": "array"
    },
    "text": {
      "title": "Text",
      "type": "string"
    },
    "uncertainty": {
      "anyOf": [
        {
          "$ref": "#/$defs/Uncertainty"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "text"
  ],
  "title": "Claim",
  "type": "object"
}
