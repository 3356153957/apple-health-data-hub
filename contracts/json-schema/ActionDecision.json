{
  "additionalProperties": false,
  "description": "The policy layer's verdict on a proposal.",
  "properties": {
    "decided_at": {
      "format": "date-time",
      "title": "Decided At",
      "type": "string"
    },
    "decided_by": {
      "enum": [
        "user",
        "policy",
        "auto"
      ],
      "title": "Decided By",
      "type": "string"
    },
    "decision": {
      "enum": [
        "approved",
        "rejected",
        "deferred"
      ],
      "title": "Decision",
      "type": "string"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "owner_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Owner Id",
      "type": "string"
    },
    "proposal_id": {
      "format": "uuid",
      "title": "Proposal Id",
      "type": "string"
    },
    "rationale": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rationale"
    },
    "workspace_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "proposal_id",
    "decided_at",
    "decision",
    "decided_by"
  ],
  "title": "ActionDecision",
  "type": "object"
}
