{
  "additionalProperties": false,
  "description": "One execution of a Source plugin pulling/receiving data.",
  "properties": {
    "ended_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ended At"
    },
    "errors_count": {
      "default": 0,
      "title": "Errors Count",
      "type": "integer"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "measurements_count": {
      "default": 0,
      "title": "Measurements Count",
      "type": "integer"
    },
    "owner_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Owner Id",
      "type": "string"
    },
    "source_id": {
      "format": "uuid",
      "title": "Source Id",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "enum": [
        "running",
        "succeeded",
        "failed",
        "partial",
        "cancelled"
      ],
      "title": "Status",
      "type": "string"
    },
    "workspace_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "source_id",
    "started_at",
    "status"
  ],
  "title": "IngestionRun",
  "type": "object"
}
