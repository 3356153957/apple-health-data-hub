{
  "$defs": {
    "Claim": {
      "additionalProperties": false,
      "description": "One assertion inside a narrative, with optional evidence + uncertainty.",
      "properties": {
        "evidence": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Evidence",
          "type": "array"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "uncertainty": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uncertainty"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "text"
      ],
      "title": "Claim",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "A pointer to a piece of evidence backing a claim.",
      "properties": {
        "kind": {
          "enum": [
            "measurement",
            "finding",
            "observation",
            "external"
          ],
          "title": "Kind",
          "type": "string"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "Insight": {
      "additionalProperties": false,
      "description": "A structured observation about the user's data.\n\nSeverity matches the existing ``analysis.types.Severity`` literal so\nthe v1 statistical engine output round-trips cleanly into v2 narratives.",
      "properties": {
        "claims": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Claim"
          },
          "title": "Claims",
          "type": "array"
        },
        "metric": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric"
        },
        "severity": {
          "default": "info",
          "enum": [
            "info",
            "watch",
            "alert"
          ],
          "title": "Severity",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "summary"
      ],
      "title": "Insight",
      "type": "object"
    },
    "SuggestedAction": {
      "additionalProperties": false,
      "description": "A user-visible suggestion. Defaults to requiring approval \u2014\nsuggestions are advisory, not auto-actuated.",
      "properties": {
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        },
        "requires_approval": {
          "default": true,
          "title": "Requires Approval",
          "type": "boolean"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "SuggestedAction",
      "type": "object"
    },
    "Uncertainty": {
      "additionalProperties": false,
      "description": "How sure the narrator is about a claim.",
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        }
      },
      "required": [
        "confidence"
      ],
      "title": "Uncertainty",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A streamable narrative \u2014 daily briefing, weekly summary, etc.\n\nThe wire shape is the *persisted* form. Streaming chunks go over\nSSE during render; once complete, the whole artifact is one row\nin this shape. The dashboard's ``BriefingCard`` reads this.",
  "properties": {
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "insights": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Insight"
      },
      "title": "Insights",
      "type": "array"
    },
    "kind": {
      "enum": [
        "daily_briefing",
        "weekly_summary",
        "anomaly_explanation",
        "intervention_proposal"
      ],
      "title": "Kind",
      "type": "string"
    },
    "narrator_plugin_id": {
      "title": "Narrator Plugin Id",
      "type": "string"
    },
    "narrator_version": {
      "title": "Narrator Version",
      "type": "string"
    },
    "owner_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Owner Id",
      "type": "string"
    },
    "rendered_at": {
      "format": "date-time",
      "title": "Rendered At",
      "type": "string"
    },
    "suggested_actions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/SuggestedAction"
      },
      "title": "Suggested Actions",
      "type": "array"
    },
    "text": {
      "title": "Text",
      "type": "string"
    },
    "workspace_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "rendered_at",
    "text",
    "narrator_plugin_id",
    "narrator_version"
  ],
  "title": "NarrativeArtifact",
  "type": "object"
}
