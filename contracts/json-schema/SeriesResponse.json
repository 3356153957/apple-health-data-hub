{
  "$defs": {
    "Annotation": {
      "additionalProperties": false,
      "description": "A point or range marker on a chart \u2014 anomaly, intervention, event.",
      "properties": {
        "at": {
          "format": "date-time",
          "title": "At",
          "type": "string"
        },
        "color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Color"
        },
        "end": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "kind": {
          "enum": [
            "point",
            "range"
          ],
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "at",
        "text"
      ],
      "title": "Annotation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Time-series data for a chart, plus annotations.\n\n``points`` is ``(timestamp, value)`` pairs \u2014 typed as a list of\ntwo-element tuples so the TS codegen produces a sensible\n``[string, number][]`` rather than an opaque object.",
  "properties": {
    "annotations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Annotation"
      },
      "title": "Annotations",
      "type": "array"
    },
    "metric": {
      "title": "Metric",
      "type": "string"
    },
    "owner_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Owner Id",
      "type": "string"
    },
    "points": {
      "items": {
        "maxItems": 2,
        "minItems": 2,
        "prefixItems": [
          {
            "format": "date-time",
            "type": "string"
          },
          {
            "type": "number"
          }
        ],
        "type": "array"
      },
      "title": "Points",
      "type": "array"
    },
    "unit": {
      "title": "Unit",
      "type": "string"
    },
    "workspace_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "metric",
    "unit",
    "points"
  ],
  "title": "SeriesResponse",
  "type": "object"
}
