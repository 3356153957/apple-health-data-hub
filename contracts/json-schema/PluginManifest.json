{
  "$defs": {
    "PluginCapability": {
      "additionalProperties": false,
      "description": "A capability a plugin declares it needs.\n\nCapabilities use the ``read:<scope>`` / ``write:<scope>`` form\n(e.g. ``read:hrv``, ``write:notifications``) so the policy layer\ncan match on prefix.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "PluginCapability",
      "type": "object"
    },
    "PluginPermissions": {
      "additionalProperties": false,
      "description": "Runtime permissions a plugin requests.",
      "properties": {
        "capabilities": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PluginCapability"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "network": {
          "default": false,
          "title": "Network",
          "type": "boolean"
        },
        "secrets": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Secrets",
          "type": "array"
        }
      },
      "title": "PluginPermissions",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Every plugin's plugin.yaml validates against this.\n\n``sdk_version`` is the SDK version range the plugin targets\n(semver, e.g. ``\">=0.1,<0.2\"``). The loader rejects plugins\nwhose declared range doesn't include the running core SDK.\nAdding this from day one means we can evolve the SDK contract\nwithout silently breaking community plugins.",
  "properties": {
    "config_schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Config Schema"
    },
    "consumes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Consumes",
      "type": "array"
    },
    "emits": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Emits",
      "type": "array"
    },
    "entrypoint": {
      "title": "Entrypoint",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "enum": [
        "source",
        "narrator",
        "agent"
      ],
      "title": "Kind",
      "type": "string"
    },
    "language": {
      "default": "python",
      "enum": [
        "python",
        "typescript"
      ],
      "title": "Language",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "permissions": {
      "$ref": "#/$defs/PluginPermissions",
      "default": {
        "capabilities": [],
        "network": false,
        "secrets": []
      }
    },
    "requires": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Requires",
      "type": "array"
    },
    "sdk_version": {
      "title": "Sdk Version",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "kind",
    "version",
    "sdk_version",
    "entrypoint"
  ],
  "title": "PluginManifest",
  "type": "object"
}
