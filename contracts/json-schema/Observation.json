{
  "additionalProperties": false,
  "description": "What the agent observed during a run. Append-only.\n\nFindings are intentionally a free-form ``dict`` to keep the\ncontract stable across narrators evolving their statistical\noutput shape.",
  "properties": {
    "captured_at": {
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "findings": {
      "title": "Findings",
      "type": "object"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "metric": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Metric"
    },
    "owner_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Owner Id",
      "type": "string"
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "workspace_id": {
      "default": "00000000-0000-0000-0000-000000000001",
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "run_id",
    "captured_at",
    "findings"
  ],
  "title": "Observation",
  "type": "object"
}
